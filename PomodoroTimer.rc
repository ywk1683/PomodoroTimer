    RTEXT           "工作时长:",IDC_STATIC,15,24,36,8
    EDITTEXT        IDC_EDIT_TIME_SPAN_WORK,62,22,30,14,ES_AUTOHSCROLL | ES_NUMBER,WS_EX_RIGHT
    CONTROL         "",IDC_SPIN_TIME_SPAN_WORK,"msctls_updown32",UDS_SETBUDDYINT | UDS_AUTOBUDDY | UDS_ARROWKEYS,94,22,10,14
