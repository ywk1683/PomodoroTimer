    LTEXT           "个工作时段使用长时间休息",IDC_STATIC,114,64,97,8
    CONTROL         "自动启动",IDC_CHECK_AUTO_START,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,93,48,10
