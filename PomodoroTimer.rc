    CONTROL         "打开选项窗口",IDC_RADIO_DC_OPEN_OPTIONS_DLG,"Button",BS_AUTORADIOBUTTON | WS_TABSTOP,129,149,64,10
    CONTROL         "播放提示音",IDC_CHECK_PLAY_SOUND,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,168,56,10
    COMBOBOX        IDC_COMBO_SOUND_LIST,66,167,144,30,CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "▶",IDC_BTN_SOUND_TEST,215,166,17,14
    LTEXT           "音量:",IDC_STATIC,15,186,24,8
    CONTROL         "",IDC_SLIDER_VOLUME,"msctls_trackbar32",TBS_AUTOTICKS | WS_TABSTOP,50,184,140,16
