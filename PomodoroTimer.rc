IDR_MENU_MAIN MENU
BEGIN
    POPUP "Func"
    BEGIN
        MENUITEM "开始(&S)",                      ID_FUNC_START
        MENUITEM "暂停(&P)",                      ID_FUNC_PAUSE
        MENUITEM "跳过(&N)",                      ID_FUNC_SKIP
        MENUITEM "停止(&T)",                      ID_FUNC_STOP
        MENUITEM SEPARATOR
        MENUITEM "选项(&O)",                      ID_FUNC_OPTIONS
    END
END


